# Polymarket wallet
PROXY_WALLET=0x...
PRIVATE_KEY=your_private_key_no_0x_prefix
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Scorio API — subscribe at https://rapidapi.com/scorio-scorio-default/api/scorio
SCORIO_API_KEY=your_rapidapi_key
SCORIO_API_HOST=scorio.p.rapidapi.com

# OpenAI (decision engine)
OPENAI_API_KEY=sk-...

# MongoDB (optional — for persistence)
MONGO_URI=mongodb://localhost:27017/scorio_polymarket

# Trading config
MAX_TRADE_SIZE=10
MIN_EDGE_PCT=2.0
SCAN_INTERVAL_S=60
DRY_RUN=true
